#if ($data.exBehaviorMap && $data.exBehaviorMap.size() > 0)
#set ($rule = $scriptEngine.get('remoteApiRule'))
<h2 id="rempteapi-$data.schema">rempteapi ($data.schema)</h2>
<table>
    <thead>
    <tr>
        <th>No.</th>
        <th>URL</th>
        <th>Http Method</th>
        <th>class#method</th>
    </tr>
    </thead>
    <tbody id="rempteapi-$data.schema-list-body">
#foreach($exBehavior in $data.exBehaviorMap.values())
#foreach($methodResource in $exBehavior.bsBehavior.methodResourceList)
    <tr>
        <td class="rowcellnum">${foreach.count}</td>
        <td class="rowcell"><a href="#$manager.htmlEscapeAsId($methodResource.api.url)::$manager.htmlEscapeAsId($methodResource.api.httpMethod)">$methodResource.api.url</a></td>
        <td class="rowcell">$methodResource.api.httpMethod</td>
#set ($behaviorRequestMethodName = $scriptEngine.invokeMethod($rule, 'behaviorRequestMethodName', $methodResource.api))
        <td class="rowcell">$manager.htmlEscape($exBehavior.className)#$manager.htmlEscape($behaviorRequestMethodName)()</td>
    </tr>
#end
#end
    </tbody>
</table>

#foreach($exBehavior in $data.exBehaviorMap.values())
#foreach($methodResource in $exBehavior.bsBehavior.methodResourceList)
<h3 id="$manager.htmlEscapeAsId($methodResource.api.url)::$manager.htmlEscapeAsId($methodResource.api.httpMethod)">
$manager.htmlEscape($methodResource.api.url) ($methodResource.api.httpMethod)
</h3>
<p>
#set ($behaviorRequestMethodName = $scriptEngine.invokeMethod($rule, 'behaviorRequestMethodName', $methodResource.api))
<span class="doctitle">Request Method:</span> <span class="docmainvalue">$manager.htmlEscape($exBehavior.className)#$manager.htmlEscape($behaviorRequestMethodName)()</span>
</p>
#if (!$methodResource.pathVariables.isEmpty())
<span class="doctitle">URL Parameter:</span>
#set ($urlParameter = {})
#set ($put = $urlParameter.put('properties', $methodResource.pathVariables))
$generator.parse("remoteapi/doc/RemoteApiDocHtmlBean.vm", null, "data", $urlParameter)
#end
#if ($methodResource.paramBean.className)
<span class="doctitle">Param as:</span> <span class="docsubvalue">$manager.htmlEscape($methodResource.paramBean.className)</span>
$generator.parse("remoteapi/doc/RemoteApiDocHtmlBean.vm", null, "data", $methodResource.paramBean)
#end
#if ($methodResource.returnBean.className)
<span class="doctitle">Return as:</span> <span class="docsubvalue">$manager.htmlEscape($methodResource.returnBean.className)</span>
$generator.parse("remoteapi/doc/RemoteApiDocHtmlBean.vm", null, "data", $methodResource.returnBean)
#end
#end
#end
#end
